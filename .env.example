# Le Bar'app - local environment variables.
# Copy to .env and adjust if needed: `cp .env.example .env`
# These values are SAFE LOCAL DEFAULTS for development only. Do NOT use them in
# production and never commit a real .env file (see .gitignore).

# ===========================================================================
# PostgreSQL
# ===========================================================================
# Credentials + database name, shared by the postgres container and the API.
DB_NAME=barapp
DB_USER=barapp
DB_PASSWORD=barapp

# Host-mapped PostgreSQL port — only for tools running directly on the host
# (psql, or the backend started OUTSIDE Docker). The API container always
# connects to "postgres:5432" on the Compose network, regardless of this value.
DB_HOST_PORT=5433

# Used ONLY when running the backend directly on the host (./mvnw spring-boot:run).
# Ignored by the dockerized API (which is wired to postgres:5432 in compose).
DB_HOST=localhost
DB_PORT=5433

# ===========================================================================
# Ports exposed on the host
# ===========================================================================
API_HOST_PORT=8080        # http://localhost:8080  -> API container :8080

# Frontend is published on TWO host ports at once from a single container:
#   FRONTEND_HTTP_PORT : clean no-port URLs on the Docker host
#                        (http://client.localhost / http://barmaker.localhost).
#                        Needs host port 80 free. If Apache/Nginx/LAMP already
#                        holds it, set this to another FREE port that DIFFERS
#                        from FRONTEND_PORT (the two must never be equal or
#                        Compose fails on a duplicate host binding), e.g.
#                        FRONTEND_HTTP_PORT=8082 -> http://client.localhost:8082.
#   FRONTEND_PORT      : legacy + LAN port, unchanged. Keeps
#                        http://localhost:8081/** and http://<LAN_IP>:8081/**.
FRONTEND_HTTP_PORT=80     # http://client.localhost , http://barmaker.localhost
FRONTEND_PORT=8081        # http://localhost:8081  -> frontend Nginx :80 (legacy/LAN)

# Backend HTTP port when running on the host without Docker (./mvnw spring-boot:run).
SERVER_PORT=8080

# ===========================================================================
# Backend application
# ===========================================================================
SPRING_PROFILES_ACTIVE=local

# JWT (HMAC) configuration. The secret must be >= 256 bits (32+ chars).
# DEV-ONLY default below — replace for anything beyond local development.
APP_JWT_SECRET=local-dev-only-jwt-secret-change-me-min-256-bits-0123456789
APP_JWT_ISSUER=le-barapp
APP_JWT_EXPIRATION_SECONDS=3600

# Exact CORS origins allowed by the API (comma-separated, no wildcard).
# The browser normally calls /api through the same-origin Nginx proxy (no CORS),
# but these keep the backend coherent for the clean hostnames and legacy host.
# When reaching the app from another device, add that LAN origin too, e.g.:
# APP_CORS_ALLOWED_ORIGINS=http://client.localhost,http://barmaker.localhost,http://localhost:8081,http://192.168.1.50:8081

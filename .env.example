# Le Bar'app - local environment variables.
# Copy to .env and adjust if needed: `cp .env.example .env`
# These values are SAFE LOCAL DEFAULTS for development only. Do NOT use them in
# production and never commit a real .env file (see .gitignore).

# --- PostgreSQL (shared by docker-compose and the backend) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=barapp
DB_USER=barapp
DB_PASSWORD=barapp

# --- Backend ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
